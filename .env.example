# Optional: open this URL when MxCAD loads (http(s) URL or site-relative path).
# Put e.g. sample.mxweb under public/mxdrawings/ and use:
# VITE_MXCAD_OPEN_FILE=/mxdrawings/sample.mxweb
# VITE_MXCAD_OPEN_FILE=

